{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowJs": true,
		"checkJs": false,
		"noEmit": true,
		"skipLibCheck": true,
		"resolveJsonModule": true
	},
	"include": [
		"./*.js"
	],
	"exclude": [
		"node_modules",
		"qa",
		"test-results"
	]
}